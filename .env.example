# Telegram API credentials, obtained from https://my.telegram.org
API_ID=123456
API_HASH=your_api_hash_here

# Bot token, obtained from @BotFather
BOT_TOKEN=your_bot_token_here

# MongoDB connection settings
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=hori_bot

# Telegram user ID of the bot owner
OWNER_ID=123456789

# Comma-separated list of additional Telegram user IDs with sudo privileges
SUDO_USERS=

# Optional: Telegram channel ID used for bot event logging (e.g. -1001234567890)
LOG_CHANNEL_ID=

# Runtime settings
ENVIRONMENT=production
LOG_LEVEL=INFO
SESSION_NAME=hori_bot
WORKERS=8
PARSE_MODE=HTML

